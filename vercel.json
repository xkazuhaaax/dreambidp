{
  "version": 2,
  "buildCommand": "npm run build",
  "public": true,
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/handler.js": {
      "runtime": "nodejs@18.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/handler.js"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ]
}
