# Environment Variables Template for Netlify + Neon Deployment
# Copy this to .env and fill in your values (DO NOT commit .env to git)

# ============================================================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================================================
# Get this from Neon dashboard: https://console.neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://neon_user:neon_password@ep-xyz.neon.tech/dreambid?sslmode=require

# ============================================================================
# APPLICATION ENVIRONMENT (REQUIRED)
# ============================================================================
NODE_ENV=production

# ============================================================================
# FRONTEND URL (REQUIRED for CORS)
# ============================================================================
# Use your Netlify site URL or custom domain
FRONTEND_URL=https://your-site.netlify.app

# Alternative (if you have custom domain):
# FRONTEND_URL=https://yourdomain.com

# ============================================================================
# VITE BUILD VARIABLES (For Frontend)
# ============================================================================
# This is used during npm run build
VITE_API_URL=https://your-site.netlify.app/api

# ============================================================================
# JWT/SECURITY (OPTIONAL but recommended for production)
# ============================================================================
# Generate a secure random string for JWT signing
# JWT_SECRET=your-super-secret-jwt-key-min-32-characters

# ============================================================================
# FILE UPLOAD CONFIGURATION (OPTIONAL)
# ============================================================================
# Max file size for uploads (in MB)
# MAX_FILE_SIZE=10

# Allowed file extensions (comma-separated)
# ALLOWED_FILE_EXTENSIONS=jpg,jpeg,png,gif,pdf

# ============================================================================
# LOGGING (OPTIONAL)
# ============================================================================
# Log level: debug, info, warn, error
# LOG_LEVEL=info

# ============================================================================
# EMAIL CONFIGURATION (if using email features)
# ============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SENDER_EMAIL=noreply@dreambid.com

# ============================================================================
# NOTES FOR NETLIFY DEPLOYMENT
# ============================================================================
# 1. Do NOT commit this file to git (it contains secrets)
# 2. Add all variables to Netlify dashboard:
#    Site dashboard → Build & deploy → Environment variables
# 3. Required variables: DATABASE_URL, NODE_ENV, FRONTEND_URL
# 4. After adding variables, trigger a new deploy:
#    - Push to main branch, OR
#    - Click "Deploy site" button in Netlify dashboard
# 5. Verify deployment with:
#    curl https://your-site.netlify.app/api/health

# ============================================================================
# NEON CONNECTION DETAILS
# ============================================================================
# To find your Neon credentials:
# 1. Go to https://console.neon.tech
# 2. Select your project
# 3. Click "Connection Details"
# 4. Copy the Full Connection String
# 5. Paste as DATABASE_URL above

# Connection String Breakdown:
# postgresql://[user]:[password]@[host]/[database]?sslmode=require
#             └──────────────────┘  └─────────────────┘  └──────────┘
#             Authentication        Database Host        SSL Mode
#                                   (Neon endpoint)      (Required)
